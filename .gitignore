# =========================================
#  simpomo-for-android (.gitignore)
#  Tauri v2 (Rust) mobile / Android + Svelte (Vite/TypeScript)
# =========================================

# --- Node / Frontend ---
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
dist/
build/
out/
.svelte-kit/
.vite/
.cache/
.parcel-cache/
*.tsbuildinfo

# --- Rust / Tauri backend (src-tauri) ---
src-tauri/target/
**/*.rs.bk
*.pdb
Cargo.lock.bak

# --- Tauri generated mobile project (src-tauri/gen) ---
# gen/android（Gradle プロジェクト）は**追跡する**。landscape 固定・immersive 全画面・署名設定の手当てを
# ビルドに乗せ、CI から脆い生成テンプレ patch を無くすため（ADR-0004 / development.md / android-release.yml）。
# 追跡しないのは「生成し直せる成果物・ローカル設定・スキーマ」だけ（署名資格情報は下の機密セクションで除外済み）。
src-tauri/gen/schemas/
src-tauri/gen/android/.gradle/
src-tauri/gen/android/.tauri/
src-tauri/gen/android/build/
src-tauri/gen/android/app/build/
src-tauri/gen/android/app/.cxx/
src-tauri/gen/android/local.properties
# 将来 iOS を足したら gen/apple も成果物だけ無視する。
src-tauri/gen/apple/
# iOS は対象外。`tauri icon` が生成する iOS アイコン資産（src-tauri/icons/ios/）も追跡しない。
src-tauri/icons/ios/

# --- Android / Gradle ---
.gradle/
local.properties
.cxx/
*.apk
*.aab

# --- Logs ---
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Testing & coverage ---
coverage/
.nyc_output/

# --- Secrets / signing keys (NEVER commit — public repo) ---
.env
.env.*
.env.local
.env.*.local
*.pem
*.key
# Android release signing keystore & its credentials
*.jks
*.keystore
keystore.properties

# --- Editor / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Claude / project-init local scaffolding (keep out of public repo) ---
.claude/
